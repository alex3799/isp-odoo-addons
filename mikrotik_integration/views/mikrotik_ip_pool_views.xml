<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Search View -->
    <record id="mikrotik_ip_pool_view_search" model="ir.ui.view">
        <field name="name">mikrotik.ip.pool.search</field>
        <field name="model">mikrotik.ip.pool</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="router_id"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_router" string="Router" context="{'group_by': 'router_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- List View -->
    <record id="mikrotik_ip_pool_view_list" model="ir.ui.view">
        <field name="name">mikrotik.ip.pool.list</field>
        <field name="model">mikrotik.ip.pool</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="name"/>
                <field name="ranges"/>
                <field name="ip_address_count" string="Total IPs"/>
                <field name="ip_available_count" string="Available"/>
                <field name="ip_assigned_count" string="Assigned"/>
                <field name="available" string="ROS Available"/>
                <field name="used" string="ROS Used"/>
                <field name="router_id"/>
                <field name="last_sync"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="mikrotik_ip_pool_view_form" model="ir.ui.view">
        <field name="name">mikrotik.ip.pool.form</field>
        <field name="model">mikrotik.ip.pool</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_addresses"
                            string="Generate Addresses"
                            type="object"
                            class="btn-primary"
                            invisible="not ranges"
                            confirm="This will create IP address records for all IPs in the ranges that don't already exist. Continue?"/>
                    <button name="%(mikrotik_router_action)s" type="action"
                            string="Go to Router"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                                name="action_view_ip_addresses"
                                class="oe_stat_button"
                                icon="fa-globe">
                            <div class="o_stat_info">
                                <field name="ip_address_count" class="o_stat_value"/>
                                <span class="o_stat_text">Total IPs</span>
                            </div>
                        </button>
                        <button type="object"
                                name="action_view_available_ips"
                                class="oe_stat_button"
                                icon="fa-check-circle">
                            <div class="o_stat_info">
                                <field name="ip_available_count" class="o_stat_value"/>
                                <span class="o_stat_text">Available</span>
                            </div>
                        </button>
                        <button type="object"
                                name="action_view_assigned_ips"
                                class="oe_stat_button"
                                icon="fa-user">
                            <div class="o_stat_info">
                                <field name="ip_assigned_count" class="o_stat_value"/>
                                <span class="o_stat_text">Assigned</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group string="Pool">
                            <field name="name"/>
                            <field name="ranges"/>
                            <field name="next_pool"/>
                        </group>
                        <group string="RouterOS Usage">
                            <field name="available" string="Available (ROS)"/>
                            <field name="used" string="Used (ROS)"/>
                            <field name="total" string="Total (ROS)"/>
                        </group>
                    </group>
                    <group string="System">
                        <field name="router_id"/>
                        <field name="mikrotik_id"/>
                        <field name="last_sync"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="mikrotik_ip_pool_action" model="ir.actions.act_window">
        <field name="name">IP Pools</field>
        <field name="res_model">mikrotik.ip.pool</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="mikrotik_ip_pool_view_search"/>
    </record>

</odoo>
