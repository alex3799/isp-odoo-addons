<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Search View -->
    <record id="mikrotik_ppp_secret_view_search" model="ir.ui.view">
        <field name="name">mikrotik.ppp.secret.search</field>
        <field name="model">mikrotik.ppp.secret</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="profile"/>
                <field name="profile_id"/>
                <field name="partner_id"/>
                <separator/>
                <filter name="filter_enabled" string="Enabled" domain="[('disabled','=',False)]"/>
                <filter name="filter_disabled" string="Disabled" domain="[('disabled','=',True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_router" string="Router" context="{'group_by': 'router_id'}"/>
                    <filter name="group_profile" string="Profile" context="{'group_by': 'profile'}"/>
                    <filter name="group_profile_id" string="PPP Profile" context="{'group_by': 'profile_id'}"/>
                    <filter name="group_disabled" string="Enabled/Disabled" context="{'group_by': 'disabled'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- List View -->
    <record id="mikrotik_ppp_secret_view_list" model="ir.ui.view">
        <field name="name">mikrotik.ppp.secret.list</field>
        <field name="model">mikrotik.ppp.secret</field>
        <field name="arch" type="xml">
            <list decoration-muted="disabled == True">
                <field name="name"/>
                <field name="profile"/>
                <field name="service"/>
                <field name="remote_address"/>
                <field name="disabled" widget="boolean_toggle"/>
                <field name="router_id"/>
                <field name="partner_id"/>
                <field name="last_sync"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="mikrotik_ppp_secret_view_form" model="ir.ui.view">
        <field name="name">mikrotik.ppp.secret.form</field>
        <field name="model">mikrotik.ppp.secret</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_push_to_router" type="object"
                            string="Push to Router" class="oe_highlight"
                            icon="fa-upload"/>
                    <button name="action_enable" type="object"
                            string="Enable"
                            invisible="disabled == False"/>
                    <button name="action_disable" type="object"
                            string="Disable"
                            invisible="disabled == True"/>
                    <button name="action_resync" type="object"
                            string="Resync" icon="fa-refresh"/>
                    <button name="action_delete_from_router" type="object"
                            string="Delete from Router"
                            class="btn-danger"
                            confirm="This will delete the PPPoE secret from the router. Continue?"/>
                    <div class="ms-auto d-flex align-items-center">
                        <span invisible="disabled == True"
                              style="display:inline-block; padding:4px 14px; border-radius:6px; background:#28a745; color:white; font-weight:600; font-size:12px;">
                            Enabled
                        </span>
                        <span invisible="disabled == False"
                              style="display:inline-block; padding:4px 14px; border-radius:6px; background:#6c757d; color:white; font-weight:600; font-size:12px;">
                            Disabled
                        </span>
                    </div>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" required="1"/>
                            <field name="password" password="True"/>
                        </group>
                        <group>
                            <field name="profile"/>
                            <field name="profile_id"/>
                            <field name="service"/>
                        </group>
                    </group>

                    <group string="Connection">
                        <field name="remote_address"/>
                        <field name="caller_id"/>
                        <field name="router_id"/>
                    </group>

                    <group string="Customer">
                        <field name="partner_id"/>
                    </group>

                    <group string="Status">
                        <field name="disabled"/>
                        <field name="mikrotik_id" readonly="1"/>
                        <field name="last_sync" readonly="1"/>
                    </group>

                    <group string="Notes">
                        <field name="comment" nolabel="1"
                               placeholder="Internal notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="mikrotik_ppp_secret_action" model="ir.actions.act_window">
        <field name="name">PPPoE Secrets</field>
        <field name="res_model">mikrotik.ppp.secret</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="mikrotik_ppp_secret_view_search"/>
        <field name="context">{'search_default_filter_enabled': 1}</field>
    </record>

</odoo>
