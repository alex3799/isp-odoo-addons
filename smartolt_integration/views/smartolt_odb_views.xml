<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="smartolt_odb_view_list" model="ir.ui.view">
        <field name="name">smartolt.odb.list</field>
        <field name="model">smartolt.odb</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="external_id"/>
                <field name="zone_id"/>
                <field name="lat"/>
                <field name="lng"/>
                <field name="status"/>
                <field name="last_sync"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="smartolt_odb_view_form" model="ir.ui.view">
        <field name="name">smartolt.odb.form</field>
        <field name="model">smartolt.odb</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="ODB Information">
                        <group>
                            <field name="name"/>
                            <field name="external_id"/>
                            <field name="zone_id"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="lat"/>
                            <field name="lng"/>
                            <field name="last_sync"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Server Action: Sync ODBs (list Actions menu) -->
    <record id="action_server_sync_from_smartolt_odb" model="ir.actions.server">
        <field name="name">Sync from SmartOLT</field>
        <field name="model_id" ref="model_smartolt_odb"/>
        <field name="binding_model_id" ref="model_smartolt_odb"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">model.sync_from_smartolt()</field>
    </record>

    <!-- Server Action: Sync ODBs Now (menu trigger) -->
    <record id="action_server_sync_odbs_menu" model="ir.actions.server">
        <field name="name">Sync ODBs Now</field>
        <field name="model_id" ref="model_smartolt_odb"/>
        <field name="state">code</field>
        <field name="code">model.sync_from_smartolt()</field>
    </record>

    <!-- Window Action -->
    <record id="smartolt_odb_action" model="ir.actions.act_window">
        <field name="name">ODBs</field>
        <field name="res_model">smartolt.odb</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu items -->
    <menuitem id="smartolt_menu_odb" name="ODBs"
              parent="smartolt_menu_root"
              action="smartolt_odb_action"
              sequence="20"/>
    <menuitem id="smartolt_menu_sync_odbs" name="Sync ODBs Now"
              parent="smartolt_menu_root"
              action="action_server_sync_odbs_menu"
              sequence="26"/>

</odoo>
