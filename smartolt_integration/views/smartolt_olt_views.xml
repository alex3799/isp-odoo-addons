<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="smartolt_olt_view_list" model="ir.ui.view">
        <field name="name">smartolt.olt.list</field>
        <field name="model">smartolt.olt</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="hardware_version"/>
                <field name="ip_address"/>
                <field name="telnet_port"/>
                <field name="snmp_port"/>
                <field name="smartolt_id"/>
                <field name="last_sync"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="smartolt_olt_view_form" model="ir.ui.view">
        <field name="name">smartolt.olt.form</field>
        <field name="model">smartolt.olt</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="OLT Information">
                        <group>
                            <field name="name"/>
                            <field name="hardware_version"/>
                            <field name="ip_address"/>
                        </group>
                        <group>
                            <field name="telnet_port"/>
                            <field name="snmp_port"/>
                            <field name="smartolt_id"/>
                            <field name="last_sync"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Server Action: Sync OLTs (list Actions menu) -->
    <record id="action_server_sync_from_smartolt_olt" model="ir.actions.server">
        <field name="name">Sync from SmartOLT</field>
        <field name="model_id" ref="model_smartolt_olt"/>
        <field name="binding_model_id" ref="model_smartolt_olt"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">model.sync_from_smartolt()</field>
    </record>

    <!-- Server Action: Sync OLTs Now (menu trigger) -->
    <record id="action_server_sync_olts_menu" model="ir.actions.server">
        <field name="name">Sync OLTs Now</field>
        <field name="model_id" ref="model_smartolt_olt"/>
        <field name="state">code</field>
        <field name="code">model.sync_from_smartolt()</field>
    </record>

    <!-- Window Action -->
    <record id="smartolt_olt_action" model="ir.actions.act_window">
        <field name="name">OLTs</field>
        <field name="res_model">smartolt.olt</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu items -->
    <menuitem id="smartolt_menu_olt" name="OLTs"
              parent="smartolt_menu_root"
              action="smartolt_olt_action"
              sequence="15"/>
    <menuitem id="smartolt_menu_sync_olts" name="Sync OLTs Now"
              parent="smartolt_menu_root"
              action="action_server_sync_olts_menu"
              sequence="25"/>

    <!-- Configuration submenu -->
    <menuitem id="smartolt_menu_config" name="Configuration"
              parent="smartolt_menu_root"
              sequence="50"/>
    <menuitem id="smartolt_menu_config_onu_types" name="ONU Types"
              parent="smartolt_menu_config"
              action="smartolt_onu_type_action"
              sequence="10"/>
    <menuitem id="smartolt_menu_config_zones" name="Zones"
              parent="smartolt_menu_config"
              action="smartolt_zone_action"
              sequence="20"/>
    <menuitem id="smartolt_menu_config_speed_profiles" name="Speed Profiles"
              parent="smartolt_menu_config"
              action="smartolt_speed_profile_action"
              sequence="30"/>

</odoo>
