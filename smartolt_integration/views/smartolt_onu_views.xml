<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Search View -->
    <record id="smartolt_onu_view_search" model="ir.ui.view">
        <field name="name">smartolt.onu.search</field>
        <field name="model">smartolt.onu</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="serial_number"/>
                <field name="external_id"/>
                <field name="customer_name"/>
                <field name="pppoe_username"/>
                <field name="olt_id"/>
                <field name="zone_id"/>
                <field name="onu_type_id"/>
                <field name="partner_id"/>
                <separator/>
                <filter name="filter_online" string="Online" domain="[('onu_status','=','online')]"/>
                <filter name="filter_offline" string="Offline" domain="[('onu_status','=','offline')]"/>
                <separator/>
                <filter name="filter_enabled" string="Enabled" domain="[('admin_status','=','enabled')]"/>
                <filter name="filter_disabled" string="Disabled" domain="[('admin_status','=','disabled')]"/>
                <separator/>
                <filter name="filter_archived" string="Archived" domain="[('active','=',False)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_olt" string="OLT" context="{'group_by': 'olt_id'}"/>
                    <filter name="group_zone" string="Zone" context="{'group_by': 'zone_id'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'onu_status'}"/>
                    <filter name="group_onu_type" string="ONU Type" context="{'group_by': 'onu_type_id'}"/>
                    <filter name="group_admin_status" string="Admin Status" context="{'group_by': 'admin_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- List View -->
    <record id="smartolt_onu_view_list" model="ir.ui.view">
        <field name="name">smartolt.onu.list</field>
        <field name="model">smartolt.onu</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="serial_number"/>
                <field name="external_id" optional="hide"/>
                <field name="onu_status" widget="badge"
                       decoration-success="onu_status == 'online'"
                       decoration-danger="onu_status == 'offline'"
                       decoration-muted="onu_status == 'unknown'"/>
                <field name="signal_quality" widget="badge"
                       decoration-success="signal_quality in ('Very good', 'Good')"
                       decoration-warning="signal_quality == 'Warning'"
                       decoration-danger="signal_quality == 'Critical'"/>
                <field name="signal_power"/>
                <field name="olt_id"/>
                <field name="board" optional="hide"/>
                <field name="port" optional="hide"/>
                <field name="onu_type_id" optional="hide"/>
                <field name="onu_mode" optional="hide"/>
                <field name="zone_id" optional="show"/>
                <field name="admin_status" widget="badge"
                       decoration-success="admin_status == 'enabled'"
                       decoration-danger="admin_status == 'disabled'"
                       optional="show"/>
                <field name="download_speed_profile" optional="hide"/>
                <field name="upload_speed_profile" optional="hide"/>
                <field name="customer_name"/>
                <field name="partner_id" optional="hide"/>
                <field name="last_sync" optional="hide"/>
                <field name="lat" optional="hide"/>
                <field name="lng" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="smartolt_onu_view_form" model="ir.ui.view">
        <field name="name">smartolt.onu.form</field>
        <field name="model">smartolt.onu</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_refresh_status" type="object"
                            string="Refresh Status" class="oe_highlight"
                            icon="fa-refresh"/>
                    <button name="action_open_in_smartolt" type="object"
                            string="Open in SmartOLT"
                            icon="fa-external-link"/>
                    <button name="action_reboot" type="object"
                            string="Reboot" class="btn-warning"
                            icon="fa-power-off"
                            confirm="Are you sure you want to reboot this ONU?"/>
                    <button name="action_enable" type="object"
                            string="Enable" class="btn-success"
                            icon="fa-check-circle"
                            invisible="admin_status == 'enabled'"/>
                    <button name="action_disable" type="object"
                            string="Disable" class="btn-secondary"
                            icon="fa-ban"
                            invisible="admin_status == 'disabled'"
                            confirm="Are you sure you want to disable this ONU?"/>
                    <button name="action_resync_config" type="object"
                            string="Resync Config"
                            icon="fa-cogs"/>
                    <button name="action_delete_onu" type="object"
                            string="Delete ONU" class="btn-danger"
                            icon="fa-trash"
                            confirm="This will permanently delete this ONU from SmartOLT. Continue?"/>
                </header>
                <sheet>
                    <!-- Prominent Status Cards Row -->
                    <div class="d-flex justify-content-start gap-3 mb-3">

                        <!-- Status: Online (green) -->
                        <div invisible="onu_status != 'online'"
                             style="display:inline-block; padding:12px 24px; border-radius:8px; text-align:center; min-width:150px; background:#28a745; color:white;">
                            <div style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:1px; opacity:0.85;">Status</div>
                            <div style="font-size:28px; font-weight:700; line-height:1.3;">Online</div>
                        </div>
                        <!-- Status: Offline (red) -->
                        <div invisible="onu_status == 'online'"
                             style="display:inline-block; padding:12px 24px; border-radius:8px; text-align:center; min-width:150px; background:#dc3545; color:white;">
                            <div style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:1px; opacity:0.85;">Status</div>
                            <div style="font-size:28px; font-weight:700; line-height:1.3;">Offline</div>
                        </div>

                        <!-- Signal Quality: Very good (green) -->
                        <div invisible="signal_quality != 'Very good'"
                             style="display:inline-block; padding:12px 24px; border-radius:8px; text-align:center; min-width:150px; background:#28a745; color:white;">
                            <div style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:1px; opacity:0.85;">Signal Quality</div>
                            <div style="font-size:24px; font-weight:700; line-height:1.3;">Very good</div>
                        </div>
                        <!-- Signal Quality: Good (green) -->
                        <div invisible="signal_quality != 'Good'"
                             style="display:inline-block; padding:12px 24px; border-radius:8px; text-align:center; min-width:150px; background:#28a745; color:white;">
                            <div style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:1px; opacity:0.85;">Signal Quality</div>
                            <div style="font-size:24px; font-weight:700; line-height:1.3;">Good</div>
                        </div>
                        <!-- Signal Quality: Warning (orange) -->
                        <div invisible="signal_quality != 'Warning'"
                             style="display:inline-block; padding:12px 24px; border-radius:8px; text-align:center; min-width:150px; background:#fd7e14; color:white;">
                            <div style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:1px; opacity:0.85;">Signal Quality</div>
                            <div style="font-size:24px; font-weight:700; line-height:1.3;">Warning</div>
                        </div>
                        <!-- Signal Quality: Critical (red) -->
                        <div invisible="signal_quality != 'Critical'"
                             style="display:inline-block; padding:12px 24px; border-radius:8px; text-align:center; min-width:150px; background:#dc3545; color:white;">
                            <div style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:1px; opacity:0.85;">Signal Quality</div>
                            <div style="font-size:24px; font-weight:700; line-height:1.3;">Critical</div>
                        </div>
                        <!-- Signal Quality: Empty / unknown (gray) -->
                        <div invisible="signal_quality in ('Very good', 'Good', 'Warning', 'Critical')"
                             style="display:inline-block; padding:12px 24px; border-radius:8px; text-align:center; min-width:150px; background:#6c757d; color:white;">
                            <div style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:1px; opacity:0.85;">Signal Quality</div>
                            <div style="font-size:24px; font-weight:700; line-height:1.3;">—</div>
                        </div>

                        <!-- Signal 1490nm (dark) -->
                        <div style="display:inline-block; padding:12px 24px; border-radius:8px; text-align:center; min-width:150px; background:#343a40; color:white;">
                            <div style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:1px; opacity:0.85;">1490nm (dBm)</div>
                            <div style="font-size:24px; font-weight:700; line-height:1.3;">
                                <field name="signal_1490" readonly="1" nolabel="1"/>
                            </div>
                        </div>

                        <!-- Signal 1310nm (dark) -->
                        <div style="display:inline-block; padding:12px 24px; border-radius:8px; text-align:center; min-width:150px; background:#343a40; color:white;">
                            <div style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:1px; opacity:0.85;">1310nm (dBm)</div>
                            <div style="font-size:24px; font-weight:700; line-height:1.3;">
                                <field name="signal_1310" readonly="1" nolabel="1"/>
                            </div>
                        </div>

                    </div>

                    <!-- ONU Details -->
                    <group string="ONU Details">
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="serial_number" readonly="1"/>
                            <field name="external_id" readonly="1"/>
                            <field name="onu_type_id" readonly="1"/>
                            <field name="onu_mode" readonly="1"/>
                            <field name="custom_profile" readonly="1"/>
                            <field name="admin_status" readonly="1" widget="badge"
                                   decoration-success="admin_status == 'enabled'"
                                   decoration-danger="admin_status == 'disabled'"/>
                        </group>
                        <group>
                            <field name="olt_id" readonly="1"/>
                            <field name="olt_name" invisible="1"/>
                            <field name="board" readonly="1"/>
                            <field name="port" readonly="1"/>
                            <field name="onu_number" readonly="1"/>
                            <field name="signal_power" readonly="1"/>
                            <field name="last_sync" readonly="1"/>
                            <field name="lat" readonly="1"/>
                            <field name="lng" readonly="1"/>
                        </group>
                    </group>

                    <!-- Network Configuration -->
                    <group string="Network Configuration">
                        <group>
                            <field name="vlan"/>
                            <field name="download_speed_profile"/>
                            <field name="upload_speed_profile"/>
                        </group>
                        <group>
                            <field name="zone_id"/>
                            <field name="odb_splitter"/>
                            <field name="address"/>
                        </group>
                    </group>

                    <!-- PPPoE Information -->
                    <group string="PPPoE Information">
                        <group>
                            <field name="pppoe_username"/>
                            <field name="pppoe_password" password="True"/>
                        </group>
                        <group>
                            <field name="assigned_ip" readonly="1"/>
                            <field name="mac_address" readonly="1"/>
                        </group>
                    </group>

                    <!-- Customer -->
                    <group string="Customer">
                        <group>
                            <field name="customer_name" readonly="1"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="freeradius_status" widget="badge"
                                   decoration-success="freeradius_status == 'active'"
                                   decoration-warning="freeradius_status == 'suspended'"
                                   decoration-muted="freeradius_status == 'not_configured'"/>
                        </group>
                    </group>

                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Server Action: Sync from SmartOLT (list Actions menu) -->
    <record id="action_server_sync_from_smartolt" model="ir.actions.server">
        <field name="name">Sync from SmartOLT</field>
        <field name="model_id" ref="model_smartolt_onu"/>
        <field name="binding_model_id" ref="model_smartolt_onu"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">model.sync_from_smartolt()</field>
    </record>

    <!-- Server Action: Sync ONUs Now (menu trigger) -->
    <record id="action_server_sync_onus_menu" model="ir.actions.server">
        <field name="name">Sync ONUs Now</field>
        <field name="model_id" ref="model_smartolt_onu"/>
        <field name="state">code</field>
        <field name="code">model.sync_from_smartolt()</field>
    </record>

    <!-- Action -->
    <record id="smartolt_onu_action" model="ir.actions.act_window">
        <field name="name">ONUs</field>
        <field name="res_model">smartolt.onu</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="smartolt_onu_view_search"/>
    </record>

    <!-- Menu -->
    <menuitem id="smartolt_menu_root" name="SmartOLT" sequence="100"/>
    <menuitem id="smartolt_menu_onu" name="ONUs"
              parent="smartolt_menu_root"
              action="smartolt_onu_action"
              sequence="10"/>
    <menuitem id="smartolt_menu_sync_onus" name="Sync ONUs Now"
              parent="smartolt_menu_root"
              action="action_server_sync_onus_menu"
              sequence="20"/>


    <!-- Server Action: Sync ONU GPS (menu trigger) -->
    <record id="action_server_sync_gps_menu" model="ir.actions.server">
        <field name="name">Sync ONU GPS — Max 3 calls/hour</field>
        <field name="model_id" ref="model_smartolt_onu"/>
        <field name="state">code</field>
        <field name="code">model.sync_gps_coordinates()</field>
    </record>

    <menuitem id="smartolt_menu_sync_gps" name="Sync ONU GPS"
              parent="smartolt_menu_root"
              action="action_server_sync_gps_menu"
              sequence="22"/>

</odoo>
